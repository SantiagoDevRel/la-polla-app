# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Meta WhatsApp Cloud API
META_WA_ACCESS_TOKEN=
META_WA_PHONE_NUMBER_ID=
META_WA_WEBHOOK_VERIFY_TOKEN=

# API-Football
API_FOOTBALL_KEY=

# Cloudflare Turnstile
# Para desarrollo local usa las keys de prueba de Cloudflare:
# Site: 1x00000000000000000000AA  Secret: 1x0000000000000000000000000000000AA
NEXT_PUBLIC_CLOUDFLARE_TURNSTILE_SITE_KEY=
CLOUDFLARE_TURNSTILE_SECRET_KEY=

# Cron / Admin sync (server-side only — never use NEXT_PUBLIC_ prefix)
CRON_SECRET=

# Meta WhatsApp App Secret (for webhook signature verification)
META_WA_APP_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
