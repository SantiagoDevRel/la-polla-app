# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Meta WhatsApp Cloud API
META_WA_ACCESS_TOKEN=
META_WA_PHONE_NUMBER_ID=
META_WA_WEBHOOK_VERIFY_TOKEN=

# API-Football
API_FOOTBALL_KEY=

# Cloudflare Turnstile
# Para desarrollo local usa las keys de prueba de Cloudflare:
# Site: 1x00000000000000000000AA  Secret: 1x0000000000000000000000000000000AA
NEXT_PUBLIC_CLOUDFLARE_TURNSTILE_SITE_KEY=
CLOUDFLARE_TURNSTILE_SECRET_KEY=

# Cron / Admin sync (server-side only — never use NEXT_PUBLIC_ prefix)
CRON_SECRET=

# Meta WhatsApp App Secret (for webhook signature verification)
META_WA_APP_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# SSO handoff signing key — used by /api/auth/handoff + /api/auth/consume
# para mantener al user logueado al toggle-ar idioma en /perfil
# (lapollacolombiana.com ↔ chickenpicks.app). Generar con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# Mínimo 32 chars. Mismo valor en local + Vercel (todos los environments).
HANDOFF_SECRET=

# Admin — teléfonos exentos del tope diario de SMS (app/api/auth/start-otp).
# E.164 sin "+", separados por coma. Mismo valor en local + Vercel.
ADMIN_PHONES_E164=

# Owner usado por scripts/seed-test-data.ts para ubicar tu cuenta. E.164 sin "+".
SEED_OWNER_PHONE=

# Tester user IDs (UUID) que saltan el cap de comprobantes (payment-proof).
# Separados por coma. Vacío = nadie bypassa el cap.
TESTER_USER_IDS=
