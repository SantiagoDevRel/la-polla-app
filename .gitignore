# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env
.env*.local

# vercel
.vercel

# PWA generated files
public/sw.js
public/sw.js.map
public/workbox-*.js
public/workbox-*.js.map

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel

# Design handoff bundle from claude.ai/design — reference only
design-handoff/

# Capacitor — el folder `android/` SI se commitea (es el proyecto nativo
# generado por `cap add android`), pero estos son outputs de Gradle que
# se regeneran en cada build y NO deben ir al repo.
/android/app/build/
/android/build/
/android/.gradle/
/android/local.properties
/android/.idea/
/android/app/release/
/android/app/debug/
*.apk
*.aab

# Keystores — JAMAS al repo. Si se filtra una upload key, no podes
# actualizar la app en Play Store. Backup va a un password manager
# o disco encriptado, no a git.
*.keystore
keystore*
*.jks
*.key
keys/
keystore.properties
!debug.keystore

.env*.local

# Capacitor iOS — el folder `ios/` SI se commitea (igual que `android/`),
# pero estos son outputs de Xcode + SPM que se regeneran en cada build
# y NO deben ir al repo.
/ios/App/build/
/ios/App/Pods/
/ios/DerivedData/
/ios/App/output/
/ios/App/App.xcworkspace/xcuserdata/
/ios/App/App.xcodeproj/xcuserdata/
/ios/App/App.xcodeproj/project.xcworkspace/xcuserdata/
*.ipa
*.dSYM.zip
*.mobileprovision
*.p12
*.p8

# Codemagic local artifacts
/build/ios/
.aider*
